<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <requires lib="gtk" version="4.0"/>
  <template class="CollieTasksTaskRow" parent="GtkListBoxRow">
    <property name="child">
      <object class="GtkBox">
        <property name="spacing">12</property>
        <property name="margin-top">6</property>
        <property name="margin-bottom">6</property>
        <property name="margin-start">12</property>
        <property name="margin-end">6</property>
        <child>
          <object class="GtkCheckButton" id="check_button">
            <property name="valign">center</property>
            <property name="tooltip-text" translatable="yes">Toggle Completed</property>
          </object>
        </child>
        <child>
          <object class="GtkLabel" id="title_label">
            <property name="hexpand">true</property>
            <property name="xalign">0</property>
            <property name="ellipsize">end</property>
            <property name="use-markup">true</property>
          </object>
        </child>
        <child>
          <object class="GtkButton" id="edit_button">
            <property name="icon-name">document-edit-symbolic</property>
            <property name="valign">center</property>
            <property name="tooltip-text" translatable="yes">Edit Task</property>
            <style>
              <class name="flat"/>
            </style>
          </object>
        </child>
        <child>
          <object class="GtkButton" id="delete_button">
            <property name="icon-name">user-trash-symbolic</property>
            <property name="valign">center</property>
            <property name="tooltip-text" translatable="yes">Delete Task</property>
            <style>
              <class name="flat"/>
            </style>
          </object>
        </child>
      </object>
    </property>
  </template>
</interface>
