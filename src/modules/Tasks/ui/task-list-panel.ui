<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <requires lib="gtk" version="4.0"/>
  <requires lib="libadwaita" version="1.5"/>
  <template class="QueueTasksTaskListPanel" parent="AdwNavigationPage">
    <property name="title" translatable="yes">Tasks</property>
    <property name="child">
      <object class="AdwToolbarView">
        <child type="top">
          <object class="AdwHeaderBar">
            <child type="start">
              <object class="GtkToggleButton" id="search_button">
                <property name="icon-name">system-search-symbolic</property>
                <property name="tooltip-text" translatable="yes">Search Tasks</property>
                <property name="sensitive">false</property>
              </object>
            </child>            
            <child type="end">
              <object class="GtkDropDown" id="state_filter">
                <property name="tooltip-text" translatable="yes">Filter by status</property>
                <property name="sensitive">false</property>
                <property name="model">
                  <object class="GtkStringList">
                    <items>
                      <item translatable="yes">All</item>
                      <item translatable="yes">Pending</item>
                      <item translatable="yes">Completed</item>
                    </items>
                  </object>
                </property>
              </object>
            </child>
            <child type="end">
              <object class="GtkButton" id="add_button">
                <property name="icon-name">list-add-symbolic</property>
                <property name="tooltip-text" translatable="yes">New Task</property>
                <property name="sensitive">false</property>
                <style>
                  <class name="accent"/>
                  <class name="raised"/>
                </style>
              </object>
            </child>
          </object>
        </child>
        <child type="top">
          <object class="GtkSearchBar" id="search_bar">
            <property name="child">
              <object class="GtkSearchEntry" id="search_entry">
                <property name="placeholder-text" translatable="yes">Filter tasks by name…</property>
                <property name="hexpand">true</property>
              </object>
            </property>
          </object>
        </child>
        <property name="content">
          <object class="GtkStack" id="stack">
            <child>
              <object class="GtkStackPage">
                <property name="name">empty</property>
                <property name="child">
                  <object class="AdwStatusPage">
                    <property name="icon-name">view-list-symbolic</property>
                    <property name="title" translatable="yes">No Group Selected</property>
                    <property name="description" translatable="yes">Select a group to see its tasks.</property>
                  </object>
                </property>
              </object>
            </child>
            <child>
              <object class="GtkStackPage">
                <property name="name">no-tasks</property>
                <property name="child">
                  <object class="AdwStatusPage">
                    <property name="icon-name">checkbox-checked-symbolic</property>
                    <property name="title" translatable="yes">No Tasks Yet</property>
                    <property name="description" translatable="yes">Add your first task to this group.</property>
                    <property name="child">
                      <object class="GtkButton" id="add_first_task_button">
                        <property name="label" translatable="yes">New Task</property>
                        <property name="halign">center</property>
                        <style>
                          <class name="pill"/>
                          <class name="suggested-action"/>
                        </style>
                      </object>
                    </property>
                  </object>
                </property>
              </object>
            </child>
            <child>
              <object class="GtkStackPage">
                <property name="name">tasks</property>
                <property name="child">
                  <object class="GtkScrolledWindow">
                    <property name="child">
                      <object class="GtkListBox" id="list_box">
                        <property name="valign">start</property>
                        <property name="selection-mode">none</property>
                        <property name="margin-top">18</property>
                        <property name="margin-bottom">18</property>
                        <property name="margin-start">12</property>
                        <property name="margin-end">12</property>
                        <style>
                          <class name="boxed-list"/>
                        </style>
                      </object>
                    </property>
                  </object>
                </property>
              </object>
            </child>
          </object>
        </property>
        <child type="bottom">
          <object class="GtkBox" id="status_bar">
            <property name="halign">center</property>
            <property name="spacing">12</property>
            <style>
              <class name="toolbar"/>
            </style>
            <child>
              <object class="GtkLabel" id="total_label">
                <style>
                  <class name="dim-label"/>
                  <class name="caption"/>
                </style>
              </object>
            </child>
            <child>
              <object class="GtkSeparator">
                <property name="orientation">vertical</property>
              </object>
            </child>
            <child>
              <object class="GtkLabel" id="pending_label">
                <style>
                  <class name="dim-label"/>
                  <class name="caption"/>
                </style>
              </object>
            </child>
            <child>
              <object class="GtkSeparator">
                <property name="orientation">vertical</property>
              </object>
            </child>
            <child>
              <object class="GtkLabel" id="completed_label">
                <style>
                  <class name="dim-label"/>
                  <class name="caption"/>
                </style>
              </object>
            </child>
            <child>
              <object class="GtkSeparator">
                <property name="orientation">vertical</property>
              </object>
            </child>
            <child>
              <object class="GtkLabel" id="important_label">
                <style>
                  <class name="dim-label"/>
                  <class name="caption"/>
                </style>
              </object>
            </child>
          </object>
        </child>
      </object>
    </property>
  </template>
</interface>
